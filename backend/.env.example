# All agent inference goes through OpenRouter (one OpenAI-compatible
# endpoint that proxies Claude, Llama, GPT-OSS, and others). Get a key at
# https://openrouter.ai/keys.
OPEN_ROUTER_API_KEY=
# Any OpenRouter model ID that supports tool calling. Defaults to a free
# model for local dev/testing; swap to a paid model (or anthropic/claude-*
# via OpenRouter) for production quality. Popular free models
# (openai/gpt-oss-120b:free, meta-llama/llama-3.3-70b-instruct:free) get
# rate-limited fast on OpenRouter's shared free tier — nvidia/nemotron-nano-9b-v2:free
# has been reliable in testing and handles tool calling correctly.
OPENROUTER_MODEL=nvidia/nemotron-nano-9b-v2:free

# Voice pipeline only (OpenAI Realtime API) — unrelated to OpenRouter above.
OPENAI_API_KEY=
